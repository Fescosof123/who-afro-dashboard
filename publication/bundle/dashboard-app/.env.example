# WHO AFRO Humanitarian Dashboard — Environment Variables Example
#
# Copy this file to .env in the dashboard-app/ folder.
# Lines starting with # are comments and are ignored at runtime.
# All variables are optional. Defaults are shown and are safe for local use.
#
# Usage:
#   cp .env.example .env   (Linux/macOS)
#   copy .env.example .env  (Windows)


# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# HTTP port the server listens on.
# Default: 3000
PORT=3000


# ---------------------------------------------------------------------------
# Response cache
# ---------------------------------------------------------------------------

# Time-to-live for the /api/dashboard-data cached response (seconds).
# Lower values increase freshness; higher values reduce upstream API load.
# Default: 120
DASHBOARD_CACHE_TTL_SECONDS=120


# ---------------------------------------------------------------------------
# WHO Disease Outbreak News (WHO DON)
# ---------------------------------------------------------------------------

# Controls whether WHO DON is fetched on each refresh cycle.
#   auto  — Try WHO DON (RSS, then HTML page fallback). If 0 FCV items are
#           returned, automatically fall back to ReliefWeb-derived outbreak
#           signals so the dashboard remains populated.
#   off   — Disable WHO DON fetching entirely. Use this when the WHO endpoint
#           is known to be unstable and you want to skip the network call.
# Default: auto
WHO_DON_MODE=auto


# ---------------------------------------------------------------------------
# ReliefWeb Reports API (optional stronger regional flood source)
# ---------------------------------------------------------------------------

# Approved ReliefWeb appname for direct Reports API access.
# Use the approved appname below when enabling direct ReliefWeb Reports API pulls.
# RELIEFWEB_APPNAME=whoafro-dashboard-a9z2
RELIEFWEB_APPNAME=

# Filter Integrity policy thresholds for ReliefWeb scope-drop governance.
# Metric used by the operational cover card:
#   dropped_scope_filtered + dropped_unmapped_country
# warn threshold controls "Filtering active" state; bad threshold controls
# "Escalate review" state.
# Recommended defaults: warn=5, bad=20
FILTER_INTEGRITY_WARN_THRESHOLD=5
FILTER_INTEGRITY_BAD_THRESHOLD=20


# ---------------------------------------------------------------------------
# UNHCR displacement data
# ---------------------------------------------------------------------------

# Sets the preferred source order for displacement/refugee figures.
#   reliefweb-first  — Use ReliefWeb-based UNHCR feed first; fall back to
#                      direct UNHCR RSS if ReliefWeb is unavailable.
#   unhcr-first      — Try direct UNHCR RSS first; fall back to ReliefWeb.
#   auto             — Let the server decide based on response codes.
# Default: reliefweb-first
UNHCR_FETCH_MODE=reliefweb-first


# ---------------------------------------------------------------------------
# ACLED conflict data
# ---------------------------------------------------------------------------

# Controls whether and when ACLED credential login is attempted.
#   on-demand  — Try the public Conflict Index CSV first; attempt credential
#                login only if access is denied (401/403).
#   always     — Always authenticate before fetching.
#   off        — Never attempt credential login; public CSV only.
# Default: on-demand
ACLED_AUTH_MODE=on-demand

# ACLED account credentials (only needed when ACLED_AUTH_MODE is not 'off').
# Leave blank for public-only access via the Conflict Index CSV.
ACLED_EMAIL=
ACLED_PASSWORD=

# Optional extra candidate URLs for the ACLED Conflict Index CSV.
# Comma-separated list. The server tries these before failing.
# Leave blank to use only the built-in default URL.
ACLED_CONFLICT_INDEX_CSV_URLS=


# ---------------------------------------------------------------------------
# ACAPS humanitarian needs
# ---------------------------------------------------------------------------

# Crawl depth for the ACAPS country archives page.
#   deep  — Fetch up to ACAPS_MAX_ARCHIVE_PAGES_DEEP pages (recommended).
#   fast  — Fetch up to ACAPS_MAX_ARCHIVE_PAGES_FAST pages (faster but
#           may miss older country entries).
# Default: deep
ACAPS_CRAWL_MODE=deep

# Maximum number of archive page fetches in fast mode.
# Default: 6
ACAPS_MAX_ARCHIVE_PAGES_FAST=6

# Maximum number of archive page fetches in deep mode.
# Default: 10
ACAPS_MAX_ARCHIVE_PAGES_DEEP=10

# How long to reuse the on-disk ACAPS cache before re-crawling (minutes).
# Default: 30
ACAPS_CACHE_TTL_MINUTES=30


# ---------------------------------------------------------------------------
# FEWS NET / IPC food security data
# ---------------------------------------------------------------------------

# How long to reuse the on-disk FEWS IPC cache before re-fetching (minutes).
# Higher values reduce calls to the FEWS Data Warehouse API.
# Default: 360 (6 hours)
FEWS_IPC_CACHE_TTL_MINUTES=360

# Timeout for each FEWS Data Warehouse API request (milliseconds).
# Default: 9000
FEWS_IPC_REQUEST_TIMEOUT_MS=9000
